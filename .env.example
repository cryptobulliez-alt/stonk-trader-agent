# Robinhood Chain
RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# NFT owner EOA — must own STONK_TOKEN_ID. Signs TBA executeCall txs and pays gas.
PRIVATE_KEY=0xyour_owner_private_key

# StonkBroker to trade with (collection is the agent identity on-chain)
STONK_TOKEN_ID=1

# LLM (optional) — thesis for each autopilot pass
LLM_API_KEY=
# openai | anthropic
LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# 0x Swap API (optional RFQ path)
ZEROX_API_KEY=

# Optional: default slippage in basis points (100 = 1%)
SLIPPAGE_BPS=100

# Safety: set to false only when you intend to broadcast signed txs.
# Dashboard Dry run toggle overrides this for the running shell (settings.json).
DRY_RUN=true

# Shell API (npm run shell:api) — proxied by Next dashboard
SHELL_PORT=8788

# MCP HTTP port (npm run mcp:http)
MCP_PORT=8787

# X / Twitter — console.x.com → Keys & Tokens
# OAuth 1.0a (Consumer Key/Secret + Access Token/Secret) — post fills
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# App-only Bearer — optional for X MCP read tools
X_BEARER_TOKEN=

# Optional overrides
# STONKBROKERS_ADDRESS=0x539CdD042c2f3d93EbC5BE7DfFf0c79F3B4fAbF0
# WATCH_POLL_MS=15000
